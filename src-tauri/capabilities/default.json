{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capability granting access to all Scrapbin commands",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "fs:default",
    "core:event:default",
    {
      "identifier": "core:event:allow-emit-to",
      "allow": [{ "channel": "vault-file-changed" }]
    },
    "core:event:allow-listen",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-title"
  ]
}
